# Copy to .env (gitignored) and fill in. Both containers read this via compose `env_file`, and feeds.yaml
# expands ${INSTAPAPER_FEED_URL} at config-load time.
#
# Your private Instapaper unread RSS feed. Get it at instapaper.com: open the section you want (Home for the
# unread queue, or a folder), click your email at the top right -> Download -> copy the RSS link. The URL carries
# a secret token granting read access to that reading list, so keep it out of version control.
INSTAPAPER_FEED_URL=https://www.instapaper.com/rss/0000000/xxxxxxxxxxxxxxxxxxxxxxxxxxxx
